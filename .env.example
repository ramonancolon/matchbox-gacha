# ──────────────────────────────────────────────────────────────
# Matchbox Gacha — Environment Variables Template
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to source control. It is listed in .gitignore.
# ──────────────────────────────────────────────────────────────


# ── Gemini AI (required for hint feature) ─────────────────────
# Get your key from: https://aistudio.google.com/apikey
# Must be a Gemini API key from AI Studio — NOT a Firebase API key.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"


# ── Firebase (required for auth, leaderboard, analytics) ──────
# Get all values from: Firebase Console → Project Settings → Your Apps → Web App
# https://console.firebase.google.com

# Found in: Project Settings → General → Project ID
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"

# Found in: Project Settings → Your Apps → App ID
VITE_FIREBASE_APP_ID="YOUR_APP_ID"

# Found in: Project Settings → Your Apps → Web API Key
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"

# Typically: your-project-id.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"

# Found in: Firestore Database → your database name (not "(default)")
VITE_FIREBASE_DATABASE_ID="YOUR_FIRESTORE_DATABASE_ID"

# Found in: Project Settings → Your Apps → storageBucket
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"

# Found in: Project Settings → Your Apps → messagingSenderId
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"

# Found in: Project Settings → Your Apps → measurementId (G-XXXXXXXX)
# Required for Firebase Analytics to fire events.
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"


# ── App (optional) ────────────────────────────────────────────
# Public URL of the deployed app. Used for OAuth callbacks and links.
APP_URL="https://your-app-url.example.com"
