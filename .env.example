# ──────────────────────────────────────────────────────────────
# Matchbox Gacha — Environment Variables Template
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to source control. It is listed in .gitignore.
# ──────────────────────────────────────────────────────────────


# ── Gemini AI (server-side only) ──────────────────────────────
# The Gemini API key is NOT set in the web app. Deploy the Firebase callable
# `getHint` (see README) and store the key as a Functions secret:
#   firebase functions:secrets:set GEMINI_API_KEY


# ── Firebase (required for auth, leaderboard, analytics) ──────
# Get all values from: Firebase Console → Project Settings → Your Apps → Web App
# https://console.firebase.google.com

# Found in: Project Settings → General → Project ID
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"

# Found in: Project Settings → Your Apps → App ID
VITE_FIREBASE_APP_ID="YOUR_APP_ID"

# Found in: Project Settings → Your Apps → Web API Key
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"

# Typically: your-project-id.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"

# Found in: Firestore Database → your database name (not "(default)")
VITE_FIREBASE_DATABASE_ID="YOUR_FIRESTORE_DATABASE_ID"

# Found in: Project Settings → Your Apps → storageBucket
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"

# Found in: Project Settings → Your Apps → messagingSenderId
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"

# Found in: Project Settings → Your Apps → measurementId (G-XXXXXXXX)
# Required for Firebase Analytics to fire events.
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# Region where `getHint` is deployed (default in code: us-central1).
# VITE_FIREBASE_FUNCTIONS_REGION="us-central1"

# Local dev flag for Functions emulator on port 5001.
# `npm run dev` sets this automatically; set manually only for custom workflows.
# VITE_FIREBASE_FUNCTIONS_EMULATOR="true"

# App Check (required when getHint enforces App Check)
# reCAPTCHA v3 site key (public) from Firebase Console → App Check → Web app.
# Set in .env for local `npm run build` / preview, and as GitHub Actions secret
# VITE_FIREBASE_APPCHECK_SITE_KEY for CI deploys. Not the reCAPTCHA secret.
VITE_FIREBASE_APPCHECK_SITE_KEY="YOUR_RECAPTCHA_V3_SITE_KEY"

# Optional: App Check debug token for local development only.
# Required when using `npm run dev:cloud` with App Check enforcement on `getHint`
# (reCAPTCHA v3 doesn't reliably sign localhost). Generate a token in your browser
# console with `self.FIREBASE_APPCHECK_DEBUG_TOKEN = true` once, register the
# printed value in Firebase Console → App Check → Apps → Manage debug tokens,
# then set it here so it's applied automatically on every dev build.
# Put this in `.env.local` (gitignored), NEVER in CI or production.
# VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=""


# ── App (optional) ────────────────────────────────────────────
# Public URL of the deployed app. Used for OAuth callbacks and links.
APP_URL="https://your-app-url.example.com"

# ── Bunny CDN (optional) ───────────────────────────────────────
# Set to your Bunny CDN pull zone URL to serve all built assets from the CDN.
# Example: https://your-pullzone.b-cdn.net
# Leave unset to serve assets from the app origin (default).
VITE_CDN_URL="https://your-pullzone.b-cdn.net"
