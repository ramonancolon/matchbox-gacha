rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUser(data) {
      return data.size() >= 1 && data.size() <= 10
        && data.displayName is string && data.displayName.size() >= 2 && data.displayName.size() <= 50
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 512));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    // Score Validation
    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'userName', 'moves', 'time', 'mode', 'theme', 'createdAt'])
        && data.keys().size() == 7
        && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 50
        && data.moves is int && data.moves > 0 && data.moves < 1000
        && data.time is int && data.time > 0 && data.time < 36000
        && data.mode in ['4', '6']
        && data.theme is string && data.theme.size() <= 20
        && data.createdAt == request.time;
    }

    match /scores/{scoreId} {
      // Secure list query
      allow list: if isSignedIn() && (
        !('mode' in request.query) || 
        (request.query.mode is string && request.query.mode.size() <= 2)
      );
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidId(scoreId) && isValidScore(incoming());
      allow update, delete: if false; // Immutable scores
    }
  }
}
