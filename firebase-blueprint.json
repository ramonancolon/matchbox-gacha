{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile information for app users",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "User's public name" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "bestMoves": { "type": "object", "description": "Map of mode to best move count" },
        "bestTime": { "type": "object", "description": "Map of mode to best time in seconds" }
      },
      "required": ["displayName"]
    },
    "Score": {
      "title": "Game Score",
      "description": "A single game completion entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the player" },
        "userName": { "type": "string", "description": "Name at time of score" },
        "userPhoto": { "type": "string", "description": "Photo at time of score" },
        "moves": { "type": "integer", "description": "Number of moves" },
        "time": { "type": "integer", "description": "Time in seconds" },
        "mode": { "type": "string", "description": "Grid size (e.g., 4, 6)" },
        "theme": { "type": "string", "description": "Card theme used" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp" }
      },
      "required": ["userId", "moves", "time", "mode", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and personal bests"
    },
    "/scores/{scoreId}": {
      "schema": "Score",
      "description": "Global activity feed and leaderboards"
    }
  }
}
