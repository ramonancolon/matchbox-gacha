{
  "name": "matchbox-gacha",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "predev:local": "npm --prefix functions ci",
    "dev:local": "concurrently -k -n EMU,WEB \"npm --prefix functions exec -- firebase emulators:start --project demo-matchbox --only functions,firestore\" \"cross-env VITE_FIREBASE_FUNCTIONS_EMULATOR=true vite --port=3000 --host=0.0.0.0\"",
    "dev:cloud": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.82",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitest/browser": "^4.1.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4"
  }
}
